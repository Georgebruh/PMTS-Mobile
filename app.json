{
  "expo": {
    "name": "PMTS-App",
    "slug": "PMTS-App",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/PMTICON.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.aboitiz.pmtsystem"
    },
    "android": {
      "package": "com.aboitiz.pmtsystem",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "plugins": [
      [
        "@morrowdigital/watermelondb-expo-plugin",
        {
          "disableJsi": true
        }
      ],
      "expo-font",
      "expo-splash-screen",
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "PMTS needs your photos so you can attach equipment images to a maintenance report.",
          "cameraPermission": "PMTS needs the camera so you can photograph equipment for a maintenance report.",
          "microphonePermission": false
        }
      ]
    ],
    "web": {
      "favicon": "./assets/favicon.png"
    }
  }
}
